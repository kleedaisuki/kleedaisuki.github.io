---
// src/pages/en/about.astro
import BaseLayout from "@layouts/BaseLayout.astro";
import { useTranslations } from "@i18n/utils";
import { getGitHubAboutData } from "../../lib/github";
import "@styles/about.css"; // 复用同一个完美的样式文件！

const lang = "en";
const t = useTranslations(lang);

const { profile: githubProfile, repos: githubRepos, profileUrl, username } =
    await getGitHubAboutData();
const hasStaticGitHubData = Boolean(githubProfile && githubRepos.length > 0);

// A small set of profile cards for the about page
const matrixData = [
    {
        quote: "Coding is the most fun when a tiny idea slowly turns into something real. C++ feels like a box of sturdy little building blocks to me.",
        tags: "Loves computers / Self-taught most of the time / Will keep poking at a bug until it behaves",
    },
    {
        quote: "Math is fun too. Following a messy trail all the way to a neat answer always makes me want to clap a little.",
        tags: "Likes logic / Enjoys proofs / Has a soft spot for elegant formulas",
    },
    {
        quote: "Books and languages feel like adventure maps. Open one up, and suddenly there's a whole new place to wander into.",
        tags: "Reads a lot / Keeps notes nearby / Sneaks in papers between classes",
    },
    {
        quote: "I really like working with AI tools. If you explain the problem clearly and try things step by step, they often help uncover fun little surprises.",
        tags: "Curious about new tools / Good at breaking problems down / Patient with prompts",
    },
    {
        quote: "School can feel a bit slow sometimes, so I usually prefer finding my own trail and running with it.",
        tags: "Likes self-directed learning / Not great at rigid routines / Always poking at something new",
    },
    {
        quote: "And yes, I love ACGN too. Cute things are very good for morale, and I like letting a little of that spark sneak into my projects.",
        tags: "Likes anime and games / Brings taste into projects / Wants things to feel both careful and lively",
    },
];
---

<BaseLayout pageTitle={t("about.title")}>
    <div
        class="about-container"
        data-github-about-root
        data-username={username}
        data-profile-url={profileUrl}
        data-has-server-data={hasStaticGitHubData ? "1" : "0"}
        data-loading-text="Syncing data from GitHub..."
        data-error-text="GitHub data is temporarily unavailable. Please try again later."
    >
        {
            githubProfile && (
                <header class="about-header" data-github-header-dynamic>
                    <img
                        src={githubProfile.avatar_url}
                        alt="GitHub Avatar"
                        class="profile-avatar"
                    />
                    <h1>{githubProfile.name || githubProfile.login}</h1>
                    <p>{githubProfile.bio}</p>
                    <a
                        class="github-profile-link"
                        href={profileUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t("about.github_profile")}
                    </a>
                </header>
            )
        }
        {
            !githubProfile && (
                <header class="about-header" data-github-header-dynamic>
                    <h1>@{username}</h1>
                    <p class="github-loading">Syncing data from GitHub...</p>
                    <a
                        class="github-profile-link"
                        href={profileUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t("about.github_profile")}
                    </a>
                </header>
            )
        }

        <section class="personality-matrix">
            <h2 class="section-title">{t("about.matrix_title")}</h2>
            <div class="matrix-grid">
                {
                    matrixData.map(({ quote, tags }) => (
                        <div class="trait-card">
                            <blockquote class="trait-card-quote">
                                {quote}
                            </blockquote>
                            <p class="trait-card-tags">{tags}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        {
            githubProfile && githubRepos.length > 0 && (
                <section
                    class="datalink-section"
                    data-github-datalink-dynamic
                >
                    <h2 class="section-title">{t("about.datalink_title")}</h2>
                    <div class="stats-grid">
                        <div class="stat-item">
                            <div class="count">{githubProfile.followers}</div>
                            <div class="label">
                                {t("about.stats_followers")}
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="count">{githubProfile.following}</div>
                            <div class="label">
                                {t("about.stats_following")}
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="count">
                                {githubProfile.public_repos}
                            </div>
                            <div class="label">{t("about.stats_repos")}</div>
                        </div>
                    </div>

                    <h3 class="section-title" style="font-size: 1.5em;">
                        {t("about.repos_title")}
                    </h3>
                    <div class="repo-grid">
                        {githubRepos.map((repo) => (
                            <div class="repo-card">
                                <a
                                    href={repo.html_url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <h4 class="repo-title">{repo.name}</h4>
                                    <p class="repo-desc">
                                        {repo.description ||
                                            t("about.repo_desc_fallback")}
                                    </p>
                                    <div class="repo-footer">
                                        <span class="repo-lang">
                                            {repo.language && (
                                                <span class="lang-dot" />
                                            )}
                                            {repo.language}
                                        </span>
                                        <span>★ {repo.stargazers_count}</span>
                                    </div>
                                </a>
                            </div>
                        ))}
                    </div>
                </section>
            )
        }
        {
            !hasStaticGitHubData && (
                <section
                    class="datalink-section"
                    data-github-datalink-dynamic
                >
                    <h2 class="section-title">{t("about.datalink_title")}</h2>
                    <p class="github-loading">Syncing data from GitHub...</p>
                </section>
            )
        }
    </div>
    <script is:inline>
        (() => {
            const root = document.querySelector("[data-github-about-root]");
            if (!root) return;

            const username = root.getAttribute("data-username");
            const profileUrl = root.getAttribute("data-profile-url");
            const hasServerData =
                root.getAttribute("data-has-server-data") === "1";
            const loadingText = root.getAttribute("data-loading-text") || "Loading...";
            const errorText = root.getAttribute("data-error-text") || "Failed to load GitHub data.";
            if (!username || !profileUrl) return;

            const headerNode = root.querySelector("[data-github-header-dynamic]");
            const datalinkNode = root.querySelector("[data-github-datalink-dynamic]");
            if (!headerNode || !datalinkNode) return;

            const setFallbackMessage = (message) => {
                [headerNode, datalinkNode].forEach((node) => {
                    if (!node) return;
                    const loadingEl = node.querySelector(".github-loading");
                    if (loadingEl) loadingEl.textContent = message;
                });
            };

            const createEl = (tag, className, text) => {
                const el = document.createElement(tag);
                if (className) el.className = className;
                if (typeof text === "string") el.textContent = text;
                return el;
            };

            const renderHeader = (profile) => {
                headerNode.innerHTML = "";

                const avatar = createEl("img", "profile-avatar");
                avatar.src = profile.avatar_url;
                avatar.alt = "GitHub Avatar";

                const name = createEl("h1", "", profile.name || profile.login || `@${username}`);
                const bio = createEl("p", "", profile.bio || "");

                const link = createEl("a", "github-profile-link", "Open GitHub Profile");
                link.href = profile.html_url || profileUrl;
                link.target = "_blank";
                link.rel = "noopener noreferrer";

                headerNode.append(avatar, name, bio, link);
            };

            const renderDatalink = (profile, repos) => {
                datalinkNode.innerHTML = "";

                const title = createEl("h2", "section-title", "GitHub Snapshot");
                datalinkNode.appendChild(title);

                const statsGrid = createEl("div", "stats-grid");
                const makeStat = (count, label) => {
                    const item = createEl("div", "stat-item");
                    item.append(createEl("div", "count", String(count)), createEl("div", "label", label));
                    return item;
                };
                statsGrid.append(
                    makeStat(profile.followers ?? 0, "Followers"),
                    makeStat(profile.following ?? 0, "Following"),
                    makeStat(profile.public_repos ?? 0, "Public Repos"),
                );
                datalinkNode.appendChild(statsGrid);

                const repoTitle = createEl("h3", "section-title", "Recently Tinkering With");
                repoTitle.style.fontSize = "1.5em";
                datalinkNode.appendChild(repoTitle);

                const repoGrid = createEl("div", "repo-grid");
                repos.forEach((repo) => {
                    const card = createEl("div", "repo-card");
                    const link = createEl("a", "");
                    link.href = repo.html_url;
                    link.target = "_blank";
                    link.rel = "noopener noreferrer";

                    const name = createEl("h4", "repo-title", repo.name);
                    const desc = createEl("p", "repo-desc", repo.description || "No description provided.");
                    const footer = createEl("div", "repo-footer");
                    const lang = createEl("span", "repo-lang");
                    if (repo.language) {
                        lang.appendChild(createEl("span", "lang-dot"));
                        lang.appendChild(document.createTextNode(repo.language));
                    }
                    const stars = createEl("span", "", `★ ${repo.stargazers_count ?? 0}`);
                    footer.append(lang, stars);
                    link.append(name, desc, footer);
                    card.appendChild(link);
                    repoGrid.appendChild(card);
                });
                datalinkNode.appendChild(repoGrid);
            };

            setFallbackMessage(loadingText);

            Promise.all([
                fetch(`https://api.github.com/users/${username}`),
                fetch(`https://api.github.com/users/${username}/repos?sort=pushed&per_page=100`),
            ])
                .then(async ([profileRes, reposRes]) => {
                    if (!profileRes.ok || !reposRes.ok) throw new Error("GitHub API error");
                    const profile = await profileRes.json();
                    const allRepos = await reposRes.json();
                    const repos = allRepos
                        .filter((repo) => !repo.fork)
                        .sort(
                            (a, b) =>
                                new Date(b.pushed_at).getTime() -
                                new Date(a.pushed_at).getTime(),
                        )
                        .slice(0, 6);

                    renderHeader(profile);
                    renderDatalink(profile, repos);
                })
                .catch(() => {
                    if (!hasServerData) {
                        setFallbackMessage(errorText);
                    }
                });
        })();
    </script>
</BaseLayout>
