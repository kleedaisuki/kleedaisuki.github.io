---
import "@styles/global.css"; // 我们把 global.css 的引用放在这里
import "@styles/fonts.css";
import Nav from "@components/Nav.astro";
import LangSwitch from "@components/LangSwitch.astro";
import { getAbsoluteLocaleUrl } from "astro:i18n";
import { getCollection, type CollectionEntry } from "astro:content";

const pathname = Astro.url.pathname;
const strip = pathname.replace(/^\/(zh|en)\//, "");
const m = pathname.match(/^\/(zh|en)\/blog\/([^/]+)\/?$/);

let alternates = (["zh", "en"] as const).map((loc) => ({
  locale: loc,
  url: getAbsoluteLocaleUrl(loc, strip),
}));

if (m) {
  const currentLocale = m[1] as "zh" | "en";
  const currentSlug = decodeURIComponent(m[2]);
  const allPosts = await getCollection("blog");

  const findPost = (locale: "zh" | "en", slug: string) =>
    allPosts.find(
      (p): p is CollectionEntry<"blog"> =>
        p.data.locale === locale && p.data.slug === slug,
    );

  const findByPair = (locale: "zh" | "en", pair: string) =>
    allPosts.find(
      (p): p is CollectionEntry<"blog"> =>
        p.data.locale === locale && p.data.pair === pair,
    );

  const currentPost = findPost(currentLocale, currentSlug);
  if (currentPost) {
    const getTargetSlug = (targetLocale: "zh" | "en") => {
      const pairedSlug = currentPost.data.pair;
      if (!pairedSlug) return null;

      if (findPost(targetLocale, pairedSlug)) return pairedSlug;

      const reverse = findByPair(targetLocale, currentSlug);
      if (reverse) return reverse.data.slug;

      return pairedSlug;
    };

    const zhSlug = currentLocale === "zh" ? currentSlug : getTargetSlug("zh");
    const enSlug = currentLocale === "en" ? currentSlug : getTargetSlug("en");

    alternates = [
      {
        locale: "zh",
        url: zhSlug
          ? getAbsoluteLocaleUrl("zh", `blog/${encodeURIComponent(zhSlug)}/`)
          : getAbsoluteLocaleUrl("zh", strip),
      },
      {
        locale: "en",
        url: enSlug
          ? getAbsoluteLocaleUrl("en", `blog/${encodeURIComponent(enSlug)}/`)
          : getAbsoluteLocaleUrl("en", strip),
      },
    ];
  }
}

const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://www.kleedaisuki.com",
).toString();
const { pageTitle } = Astro.props as { pageTitle?: string };
---

<html lang={Astro.currentLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.locale} href={a.url} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={getAbsoluteLocaleUrl("zh", "")}
    />
    <title>{pageTitle ?? "kleedaisuki"}</title>
  </head>
  <body>
    <div class="site-wrapper">
      <header class="container">
        <Nav />
        <LangSwitch />
      </header>
      <main class="container">
        <slot />
      </main>
      <footer class="container">
        © 2024-{new Date().getFullYear()} kleedaisuki ✨<br />
        <a
          href="http://creativecommons.org/licenses/by-nc-sa/4.0/"
          rel="license"
        >
          CC BY-NC-SA 4.0
        </a>
      </footer>
    </div>
  </body>
</html>
